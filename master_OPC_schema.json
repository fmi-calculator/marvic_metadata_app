{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/opc-master-record.schema.json",
  "title": "OPC Master Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_metadata",
    "factsheet",
    "models",
    "uncertainty_propagation",
    "validation_evidence_overview",
    "crcf_model_readiness_matrix"
  ],
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1
    },
    "scaleEnum": {
      "type": "string",
      "enum": [
        "pixel",
        "point",
        "parcel",
        "field",
        "farm",
        "project",
        "region",
        "other"
      ]
    },
    "uncertaintySource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["propagated", "propagation_method"],
      "properties": {
        "count": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of distinct variables in this source category (e.g. number of state variables for initial_conditions, number of driver variables for drivers)."
        },
        "data_driven": {
          "type": "boolean",
          "description": "True if this source's inputs are derived directly from measured/observational data; false for spin-up, hand-tuned, or theoretical defaults."
        },
        "top_inputs": {
          "type": "array",
          "maxItems": 5,
          "items": { "type": "string" },
          "description": "Up to 5 names of the most important data inputs in this source category."
        },
        "propagated": {
          "type": "boolean"
        },
        "propagation_method": {
          "type": "string"
        }
      }
    },
    "crcfCriterionDetail": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["met", "partly_met", "not_met", "not_applicable", "unclear"]
        },
        "short_justification": { "type": "string" },
        "priority_for_improvement": {
          "type": "string",
          "enum": ["low", "medium", "high", "critical"]
        },
        "evidence_notes": { "type": "string" },
        "bias": { "type": "boolean" },
        "pi": { "type": "boolean" },
        "r2": { "type": "boolean" }
      }
    }
  },
  "properties": {
    "record_metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "opc_id", "created_by", "last_updated"],
      "properties": {
        "schema_version": {
          "type": "string",
          "examples": ["1.0.0"]
        },
        "opc_id": {
          "type": "string",
          "pattern": "^[a-z0-9_\\-]+$",
          "examples": ["carbs", "carbonextract", "daycent_cr"]
        },
        "created_by": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "last_updated": {
          "type": "string",
          "format": "date"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "factsheet": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "opc_name",
        "lead_institutions",
        "main_modelling_approach",
        "target_lusts",
        "geographic_focus",
        "ghgs_covered",
        "reporting_scale",
        "update_frequency",
        "user_orientation",
        "operational_maturity",
        "openness_level",
        "validation_status"
      ],
      "properties": {
        "opc_name": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "opc_fullname": {
          "type": "string"
        },
        "lead_institutions": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "main_modelling_approach": {
          "type": "string",
          "enum": ["soil-centred", "ecosystem-based", "hybrid", "multi-model"]
        },
        "target_lusts": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "geographic_focus": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/nonEmptyString"
          }
        },
        "ghgs_covered": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["SOC", "CO2", "N2O", "CH4", "RECO", "GPP", "NECB", "other"]
          }
        },
        "crop_types_supported": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "cereals",
              "maize",
              "oilseeds",
              "pulses",
              "legumes",
              "grassland",
              "root vegetables",
              "leafy vegetables",
              "vegetables - other",
              "shrubs",
              "trees",
              "mixed",
              "other"
            ]
          }
        },
        "cf_practices_covered": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "Crop rotation",
              "Cover crops",
              "Organic amendments",
              "Reduced tillage",
              "Residue management"
            ]
          }
        },
        "reporting_scale": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/scaleEnum"
          }
        },
        "update_frequency": {
          "type": "string",
          "enum": [
            "subdaily",
            "daily",
            "monthly",
            "subannual",
            "annual",
            "multi-annual",
            "event-based",
            "on-demand",
            "other"
          ]
        },
        "user_orientation": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "research",
              "operational_MRV",
              "certification",
              "advisory",
              "registry",
              "auditor",
              "farmer",
              "mixed",
              "other"
            ]
          }
        },
        "operational_maturity": {
          "type": "string",
          "enum": [
            "01_concept",
            "02_prototype",
            "03_pilot",
            "04_operational",
            "05_other"
          ]
        },
        "openness_level": {
          "type": "string",
          "enum": ["fully_open", "partly_open", "closed", "mixed"]
        },
        "validation_status": {
          "type": "string",
          "enum": [
            "not_validated",
            "validation_planned",
            "under_validation",
            "partly_validated",
            "validated_limited_domain",
            "validated_operational_domain",
            "independently_validated"
          ]
        },
        "validation_status_notes": {
          "type": "string"
        },
        "baseline_approach": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "baseline_type": {
              "type": "string",
              "enum": [
                "farm_specific",
                "activity_specific",
                "regional_reference",
                "standardised",
                "dynamic_modelled",
                "control_plot",
                "mixed",
                "unclear"
              ]
            },
            "baseline_history_required": { "type": "boolean" },
            "baseline_auditability": {
              "type": "string",
              "enum": ["high", "medium", "low", "unclear"]
            }
          }
        },
        "input_dependency_profile": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "requires_field_management_data": { "type": "boolean" },
            "requires_soil_sampling": { "type": "boolean" },
            "requires_lab_analysis": { "type": "boolean" },
            "requires_optical_eo": { "type": "boolean" },
            "requires_sar_eo": { "type": "boolean" },
            "requires_weather_data": { "type": "boolean" },
            "most_critical_bottleneck": {
              "type": "string",
              "enum": [
                "management_data",
                "soil_data",
                "eo_availability",
                "weather_data",
                "crop_parameters",
                "validation_data",
                "compute",
                "other"
              ]
            }
          }
        },
        "interoperability": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "input_interfaces": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "api",
                  "file_upload",
                  "database",
                  "manual_form",
                  "other"
                ]
              }
            },
            "output_formats": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "json",
                  "csv",
                  "geotiff",
                  "netcdf",
                  "parquet",
                  "pdf",
                  "other"
                ]
              }
            },
            "integrates_with_fmis": { "type": "boolean" },
            "integrates_with_lpis": { "type": "boolean" },
            "integrates_with_lab_data": { "type": "boolean" },
            "integrates_with_eo_pipeline": { "type": "boolean" },
            "machine_readable_io_schema": { "type": "boolean" }
          }
        },
        "runtime_environment": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "execution_targets": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": ["laptop", "workstation", "server", "cloud", "hpc"]
              }
            },
            "containerised": { "type": "boolean" },
            "container_tech": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": ["docker", "podman", "singularity", "none", "other"]
              }
            },
            "requires_parallelisation": { "type": "boolean" },
            "minimum_compute_notes": { "type": "string" }
          }
        },
        "automation_profile": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "data_ingestion": {
              "type": "string",
              "enum": ["manual", "semi_automated", "automated"]
            },
            "preprocessing": {
              "type": "string",
              "enum": ["manual", "semi_automated", "automated"]
            },
            "model_execution": {
              "type": "string",
              "enum": ["manual", "semi_automated", "automated"]
            },
            "qa_qc": {
              "type": "string",
              "enum": ["manual", "semi_automated", "automated"]
            },
            "report_generation": {
              "type": "string",
              "enum": ["manual", "semi_automated", "automated"]
            }
          }
        }
      }
    },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["model_name", "model_role", "scientific_publication_dois"],
        "properties": {
          "model_name": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "model_role": {
            "type": "string",
            "enum": [
              "core",
              "upstream",
              "plant",
              "soil",
              "ecosystem",
              "downstream",
              "assimilation",
              "auxiliary",
              "other"
            ]
          },
          "model_version": {
            "type": "string"
          },
          "model_repository": {
            "type": "string",
            "format": "uri"
          },
          "scientific_publication_dois": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/nonEmptyString"
            },
            "uniqueItems": true
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "uncertainty_propagation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "initial_conditions",
        "drivers",
        "parameters",
        "management",
        "process_error",
        "random_effects",
        "project_scale"
      ],
      "properties": {
        "initial_conditions": { "$ref": "#/$defs/uncertaintySource" },
        "drivers": { "$ref": "#/$defs/uncertaintySource" },
        "parameters": { "$ref": "#/$defs/uncertaintySource" },
        "management": { "$ref": "#/$defs/uncertaintySource" },
        "process_error": { "$ref": "#/$defs/uncertaintySource" },
        "random_effects": { "$ref": "#/$defs/uncertaintySource" },
        "project_scale": { "type": "boolean" }
      }
    },
    "validation_evidence_overview": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "variable_validated",
          "dataset_type",
          "geography",
          "period",
          "validation_metrics",
          "summary_result",
          "remaining_gap"
        ],
        "properties": {
          "variable_validated": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "dataset_type": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "geography": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "period": {
            "$ref": "#/$defs/nonEmptyString"
          },
          "validation_metrics": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/nonEmptyString"
            }
          },
          "summary_result": {
            "type": "string"
          },
          "remaining_gap": {
            "type": "string"
          }
        }
      }
    },
    "crcf_model_readiness_matrix": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "assessment_unit": {
          "type": "string",
          "enum": ["OPC", "model_component"]
        },
        "applies_to_model_name": { "type": "string" },
        "eligibility_pathway": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "national_inventory_model": { "type": "boolean" },
            "commission_compliant_model": { "type": "boolean" }
          }
        },
        "model_compliance_criteria": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "transparency_traceability": {
              "$ref": "#/$defs/crcfCriterionDetail"
            },
            "scientific_credibility": { "$ref": "#/$defs/crcfCriterionDetail" },
            "suitability": { "$ref": "#/$defs/crcfCriterionDetail" },
            "minimum_accuracy": { "$ref": "#/$defs/crcfCriterionDetail" }
          }
        },
        "verification_profile": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "practice_verification_evidence": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "fmis",
                  "eo",
                  "machine_logs",
                  "photos",
                  "invoices",
                  "lab_data",
                  "field_visits",
                  "other"
                ]
              }
            },
            "outcome_verification_evidence": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "type": "string",
                "enum": [
                  "soil_sampling",
                  "flux_towers",
                  "yield_data",
                  "eo",
                  "benchmark_sites",
                  "independent_datasets",
                  "other"
                ]
              }
            },
            "field_visits_required": {
              "type": "string",
              "enum": ["never", "sometimes", "always", "unclear"]
            }
          }
        }
      }
    }
  }
}
